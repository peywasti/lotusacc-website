---
import Layout from "../layouts/Layout.astro";
---

<Layout title="لوتوس | موسسه حسابداری و حسابرسی">
  <!-- HERO -->
  <section
    id="hero"
    class="relative flex items-center justify-center min-h-[92vh] overflow-hidden bg-gradient-to-br from-slate-900 via-primary-900 to-slate-800"
  >
    <!-- Decorative animated blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-500/20 rounded-full blur-[100px] animate-blob"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-500/10 rounded-full blur-[100px] animate-blob animation-delay-2000"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-400/10 rounded-full blur-[120px] animate-blob animation-delay-4000"
      >
      </div>
    </div>

    <!-- Subtle grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
    >
    </div>

    <div class="relative z-10 text-center max-w-4xl px-6 pt-20">
      <div class="animate-on-scroll">
        <span
          class="inline-block px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/80 text-sm font-medium mb-6"
        >
          بیش از ۲۴ سال تجربه حرفه‌ای
        </span>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-white"
        >
          لوتوس؛ شروع همکاری راحت،<br class="hidden md:block" />
          <span class="text-accent-400">نتیجه حرفه‌ای</span> برای هر نوع کسب‌وکار.
        </h1>
      </div>
      <p
        class="animate-on-scroll delay-100 mt-8 text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto"
      >
        ارائه خدمات حسابداری شرکتی و حسابرسی دفاتر مالی با رویکردی دقیق، سریع و
        مطابق استانداردهای مالیاتی.
      </p>
      <div
        class="animate-on-scroll delay-200 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
      >
        <a
          href="#moshavereh"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-accent-500 to-accent-600 text-white text-base font-bold rounded-full hover:from-accent-400 hover:to-accent-500 transition-all shadow-lg shadow-accent-500/25 hover:shadow-accent-500/40 transform hover:-translate-y-0.5"
        >
          درخواست مشاوره رایگان
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white/10 backdrop-blur-sm border border-white/20 text-white text-base font-semibold rounded-full hover:bg-white/20 transition-all"
        >
          مشاهده خدمات
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg
        class="w-6 h-6 text-white/40"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="w-full py-24 bg-white">
    <div class="max-w-[1150px] mx-auto px-4">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="inline-block text-primary-600 font-semibold text-sm tracking-wider"
          >درباره ما</span
        >
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-3">
          تیمی با بیش از ۲۴ سال تجربه
        </h2>
        <div
          class="w-16 h-1 bg-gradient-to-l from-primary-600 to-accent-500 rounded-full mt-4 mx-auto"
        >
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div
          class="space-y-6 text-justify text-gray-700 leading-relaxed text-base md:text-lg animate-on-scroll"
        >
          <p>
            واحد خدمات مالی لوتوس با یک هدف ساده ساخته شده است: کمک کنیم
            کسب‌وکارها یک بخش مالی منظم، دقیق و بی‌دردسر داشته باشند.
          </p>
          <p>
            ما بیش از ۲۴ سال تجربه واقعی در حسابداری، حسابرسی داخلی و پرونده‌های
            مالیاتی داریم، عضو انجمن حسابداری و انجمن حسابداران خبره ایران
            هستیم، یعنی کار را از روی تجربه و استانداردهای حسابداری جلو می‌بریم،
            نه آزمون و خطا.
          </p>
          <p>
            لوتوس جایی است که کار حسابداری و سامانه مودیان را دقیق، درست و بدون
            استرس برای شرکت‌ها و اشخاص حقیقی انجام می‌دهد، تا مدیران و صاحبان
            کسب و کارها با خیالی راحت روی رشد کسب و کارشان تمرکز کنند.
          </p>
        </div>

        <div class="space-y-6 animate-on-scroll delay-100">
          <div
            class="bg-gradient-to-br from-primary-50 to-primary-100/50 border border-primary-100 rounded-2xl p-8 relative overflow-hidden"
          >
            <div
              class="absolute top-0 left-0 w-32 h-32 bg-primary-200/30 rounded-full blur-2xl -translate-x-1/2 -translate-y-1/2"
            >
            </div>
            <p
              class="relative text-primary-800 text-xl md:text-2xl font-bold leading-relaxed"
            >
              لوتوس کاری می‌کند که جریان مالی در شرکت یا کسب و کار شما، بالاخره
              روی ریل بیفتد.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div
              class="bg-slate-50 rounded-xl p-5 text-center border border-slate-100"
            >
              <span class="block text-3xl font-extrabold text-primary-700"
                >+۲۴</span
              >
              <span class="text-sm text-gray-600 mt-1 block">سال تجربه</span>
            </div>
            <div
              class="bg-slate-50 rounded-xl p-5 text-center border border-slate-100"
            >
              <span class="block text-3xl font-extrabold text-primary-700"
                >+۵۰۰</span
              >
              <span class="text-sm text-gray-600 mt-1 block">پرونده موفق</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="w-full bg-slate-50 py-24">
    <div class="max-w-[1150px] mx-auto px-4">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="inline-block text-primary-600 font-semibold text-sm tracking-wider"
          >خدمات ما</span
        >
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-3">
          خدمات لوتوس
        </h2>
        <p
          class="mt-5 text-gray-600 text-base md:text-lg leading-relaxed max-w-2xl mx-auto"
        >
          ما در لوتوس سعی کرده‌ایم بهترین و دقیق‌ترین خدمات مالی و حسابداری را
          برای تمامی کسب و کارها، از کارخانجات و شرکت‌ها گرفته تا فروشگاه‌ها و
          کسب و کارهای خصوصی، ارائه دهیم.
        </p>
        <div
          class="w-16 h-1 bg-gradient-to-l from-primary-600 to-accent-500 rounded-full mt-4 mx-auto"
        >
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Service 1 -->
        <div
          class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-900/5 transition-all duration-300 animate-on-scroll delay-100"
        >
          <div
            class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center mb-4 group-hover:bg-primary-700 group-hover:text-white transition-colors duration-300 text-primary-700"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">
            حسابداری و ثبت اسناد
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            ثبت و نظم‌دهی کامل اسناد مالی، تهیه تراز ماهانه و گزارش‌های سهل
            الفهم برای مدیران و صاحبان کسب و کارها.
          </p>
        </div>

        <!-- Service 2 -->
        <div
          class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-900/5 transition-all duration-300 animate-on-scroll delay-200"
        >
          <div
            class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center mb-4 group-hover:bg-primary-700 group-hover:text-white transition-colors duration-300 text-primary-700"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">
            مالیات و سامانه مودیان
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            راه‌اندازی و مدیریت سامانه مودیان، ارسال درست فاکتورها، رفع خطاها و
            کاهش ریسک جرائم مالیاتی.
          </p>
        </div>

        <!-- Service 3 -->
        <div
          class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-900/5 transition-all duration-300 animate-on-scroll delay-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center mb-4 group-hover:bg-primary-700 group-hover:text-white transition-colors duration-300 text-primary-700"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">حسابرسی داخلی</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            بررسی دقیق حساب‌ها، پیدا کردن خطاها و مغایرت‌های بانکی و سایر
            مغایرتها و ارائه راهکارهای اصلاحی برای بهبود سیستم مالی.
          </p>
        </div>

        <!-- Service 4 -->
        <div
          class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-900/5 transition-all duration-300 animate-on-scroll delay-400"
        >
          <div
            class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center mb-4 group-hover:bg-primary-700 group-hover:text-white transition-colors duration-300 text-primary-700"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">
            مشاوره تخصصی پرونده‌های مالیاتی
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            بررسی کامل وضعیت مالیاتی سال‌های قبل، تحلیل جرائم احتمالی، ارائه
            راهکارهای کاهش یا رفع جرائم، و همراهی حرفه‌ای در رسیدگی‌ها.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WORKFLOW -->
  <section id="workflow" class="w-full bg-white py-24">
    <div class="max-w-[1150px] mx-auto px-4">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="inline-block text-primary-600 font-semibold text-sm tracking-wider"
          >روند همکاری</span
        >
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-3">
          نحوه شروع همکاری با لوتوس
        </h2>
        <p
          class="mt-5 text-gray-600 text-base md:text-lg leading-relaxed max-w-2xl mx-auto"
        >
          همکاری با لوتوس برای همه نوع کسب‌وکار، چه شرکت‌ها، چه کارخانجات و چه
          کسب‌وکارهای شخصی؛ ساده، سریع و بدون پیچیدگی طراحی شده است.
        </p>
        <div
          class="w-16 h-1 bg-gradient-to-l from-primary-600 to-accent-500 rounded-full mt-4 mx-auto"
        >
        </div>
      </div>

      <div class="relative">
        <!-- Desktop connecting line -->
        <div
          class="hidden md:block absolute top-[2.25rem] right-[12.5%] left-[12.5%] h-0.5 bg-gradient-to-l from-primary-200 via-primary-300 to-primary-200"
        >
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Step 1 -->
          <div class="relative text-center animate-on-scroll delay-100">
            <div
              class="relative z-10 w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-primary-600 to-primary-800 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-primary-900/20 ring-4 ring-white"
            >
              ۱
            </div>
            <div class="mt-5">
              <h3 class="text-lg font-bold text-gray-900">تماس اولیه</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                در یک تماس کوتاه، نوع فعالیت شما و دغدغه‌های مالی، حسابداری یا
                سامانه مودیان را از شما می‌پرسیم.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="relative text-center animate-on-scroll delay-200">
            <div
              class="relative z-10 w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-primary-600 to-primary-800 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-primary-900/20 ring-4 ring-white"
            >
              ۲
            </div>
            <div class="mt-5">
              <h3 class="text-lg font-bold text-gray-900">بررسی اولیه</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                چند گزارش ساده مانند تراز و گردش مالی را دریافت کرده و تحلیل
                دقیق انجام می‌دهیم.
              </p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="relative text-center animate-on-scroll delay-300">
            <div
              class="relative z-10 w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-primary-600 to-primary-800 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-primary-900/20 ring-4 ring-white"
            >
              ۳
            </div>
            <div class="mt-5">
              <h3 class="text-lg font-bold text-gray-900">ارائه راهکار شفاف</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                نتیجه بررسی را روشن و قابل‌فهم ارائه می‌کنیم: مشکل دقیقاً کجاست،
                چه ریسکی وجود دارد، و سریع‌ترین راه‌حل چیست.
              </p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="relative text-center animate-on-scroll delay-400">
            <div
              class="relative z-10 w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-accent-500 to-accent-600 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-accent-500/20 ring-4 ring-white"
            >
              ۴
            </div>
            <div class="mt-5">
              <h3 class="text-lg font-bold text-gray-900">شروع خدمات</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                پس از تأیید شما، تیم لوتوس سریعاً کار را آغاز می‌کند. خدمات
                متناسب با نوع فعالیت شما شروع خواهد شد.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONSULTATION FORM -->
  <section
    id="moshavereh"
    class="w-full bg-gradient-to-b from-slate-50 to-white py-24"
  >
    <div class="max-w-[640px] mx-auto px-4">
      <div class="text-center mb-10 animate-on-scroll">
        <span
          class="inline-block text-primary-600 font-semibold text-sm tracking-wider"
          >مشاوره رایگان</span
        >
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-3">
          درخواست مشاوره
        </h2>
        <p class="mt-4 text-gray-600 text-base md:text-lg leading-relaxed">
          برای دریافت مشاوره حرفه‌ای، لطفاً فرم زیر را پر کنید تا تیم لوتوس با
          شما تماس بگیرد.
        </p>
      </div>

      <!-- Message Area -->
      <div id="message-area" class="mb-6 hidden">
        <div
          id="success-message"
          class="hidden bg-green-50 border border-green-200 rounded-xl p-4 text-green-800"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-green-600 shrink-0"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="font-semibold">پیام شما با موفقیت ارسال شد!</span>
          </div>
          <p class="mt-2 text-sm text-green-700">
            تیم لوتوس در اولین فرصت با شما تماس خواهد گرفت.
          </p>
        </div>

        <div
          id="error-message"
          class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-red-800"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-red-600 shrink-0"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="font-semibold">خطا در ارسال پیام</span>
          </div>
          <p id="error-text" class="mt-2 text-sm text-red-700"></p>
        </div>
      </div>

      <!-- Consultation Form -->
      <form
        id="contact-form"
        class="bg-white rounded-2xl border border-slate-100 shadow-lg shadow-slate-200/50 p-6 md:p-8 flex flex-col gap-5 animate-on-scroll delay-100"
      >
        <!-- Name -->
        <div class="flex flex-col text-right">
          <label for="name" class="mb-2 text-gray-700 font-semibold text-sm">
            نام و نام خانوادگی <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="نام و نام خانوادگی خود را وارد کنید"
            class="border border-slate-200 rounded-xl px-4 py-3 bg-slate-50 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition"
          />
        </div>

        <!-- Mobile -->
        <div class="flex flex-col text-right">
          <label for="mobile" class="mb-2 text-gray-700 font-semibold text-sm">
            شماره موبایل <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            id="mobile"
            name="mobile"
            required
            placeholder="مثال: 0912xxxxxxx"
            class="border border-slate-200 rounded-xl px-4 py-3 bg-slate-50 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition"
          />
        </div>

        <!-- Business Type -->
        <div class="flex flex-col text-right">
          <label
            for="business"
            class="mb-2 text-gray-700 font-semibold text-sm"
          >
            نوع کسب و کار
          </label>
          <select
            id="business"
            name="business"
            class="border border-slate-200 rounded-xl px-4 py-3 bg-slate-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition"
          >
            <option value="">انتخاب کنید</option>
            <option value="company">کارخانجات و شرکت‌ها</option>
            <option value="personal">فروشگاه و کسب‌وکار شخصی</option>
          </select>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          id="submit-btn"
          class="mt-2 bg-gradient-to-r from-primary-700 to-primary-800 text-white font-bold px-6 py-3.5 rounded-xl hover:from-primary-600 hover:to-primary-700 transition-all shadow-lg shadow-primary-900/15 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="btn-text">ارسال درخواست</span>
          <svg
            id="btn-spinner"
            class="w-5 h-5 animate-spin hidden"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
            ></path>
          </svg>
        </button>
      </form>

      <script is:inline>
        const form = document.getElementById("contact-form");
        const messageArea = document.getElementById("message-area");
        const successMessage = document.getElementById("success-message");
        const errorMessage = document.getElementById("error-message");
        const errorText = document.getElementById("error-text");
        const submitBtn = document.getElementById("submit-btn");
        const btnText = document.getElementById("btn-text");
        const btnSpinner = document.getElementById("btn-spinner");

        function showMessage(type, text) {
          successMessage?.classList.add("hidden");
          errorMessage?.classList.add("hidden");
          messageArea?.classList.remove("hidden");
          if (type === "success") {
            successMessage?.classList.remove("hidden");
          } else {
            errorMessage?.classList.remove("hidden");
            if (errorText && text) errorText.textContent = text;
          }
          messageArea?.scrollIntoView({ behavior: "smooth", block: "center" });
        }

        function setLoading(loading) {
          if (loading) {
            submitBtn.disabled = true;
            btnText.textContent = "در حال ارسال...";
            btnSpinner.classList.remove("hidden");
          } else {
            submitBtn.disabled = false;
            btnText.textContent = "ارسال درخواست";
            btnSpinner.classList.add("hidden");
          }
        }

        if (form) {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            setLoading(true);

            const formData = new FormData(form);
            const data = {
              name: formData.get("name"),
              mobile: formData.get("mobile"),
              business: formData.get("business"),
            };

            try {
              const res = await fetch("/api/send-email", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
              });
              const result = await res.json();
              if (result.success) {
                showMessage("success");
                form.reset();
              } else {
                showMessage("error", result.error);
              }
            } catch (error) {
              showMessage(
                "error",
                "خطا در اتصال به سرور. لطفاً دوباره تلاش کنید.",
              );
            } finally {
              setLoading(false);
            }
          });
        }
      </script>
    </div>
  </section>

